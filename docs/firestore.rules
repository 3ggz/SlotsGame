// Diamond Casino — Firestore security rules
// Paste into Firebase Console → Firestore Database → Rules → Publish.
//
// Model:
//   /config/global           world-readable feature flags, owner-only writable
//   /globals/stats           single doc, world-readable, world-incrementable
//   /recentJackpots/*        world-readable, append-only (auth required)
//   /tablePresence/*         world-readable active-table heartbeats
//   /rocketRoundCashouts/*   world-readable, append-only cashout dots
//   /rocketChat/*            world-readable, append-only short chat
//   /rocketClock/{uid}       owner-only clock sync pings for shared rounds
//   /rouletteRoundWins/*     world-readable, append-only roulette win feed
//   /rouletteChat/*          world-readable, append-only short chat
//   /rouletteClock/{uid}     owner-only clock sync pings for shared rounds
//   /users/{uid}             only the owner can read/write their record
//
// Unauthenticated visitors can read everything (so the lobby's LIVE
// panel works without forcing a sign-in). Writes require auth —
// anonymous Firebase Auth counts, and casino-account.js calls
// signInAnonymously() on every page load, so this is invisible to
// the player.

rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {

    // Owner-controlled feature flags (e.g. botsEnabled). Anyone can
    // read so every visitor sees the current state synchronously,
    // but only the owner account can flip switches. Email-based
    // gating works because the owner signs in with Google.
    match /config/global {
      allow read:  if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'mark.hacz@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // Global counters: anyone can read, any authed visitor can bump.
    match /globals/stats {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Global jackpot pools (Mini / Minor / Major / Grand).
    // World-readable so the lobby ticker works without an account;
    // authed clients run a transaction to siphon a % of every bet
    // and atomically reset on trigger.
    match /globals/jackpots {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Append-only jackpot ticker.
    match /recentJackpots/{id} {
      allow read:   if true;
      allow create: if request.auth != null
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount < 100000000
        && request.resource.data.game is string
        && request.resource.data.game.size() < 64
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64;
      allow update, delete: if false;
    }

    // Active table/lobby presence. Used by the lobby to show ×N badges
    // when more than one player is at a table.
    match /tablePresence/{id} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.game is string
        && request.resource.data.game.size() < 64
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() < 96
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64
        && request.resource.data.lastSeen is number;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Rocket crash-table cashout dots, scoped by deterministic round id.
    match /rocketRoundCashouts/{roundId}/cashouts/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.roundId == roundId
        && request.resource.data.multiplier is number
        && request.resource.data.multiplier >= 1
        && request.resource.data.multiplier < 1000
        && request.resource.data.bet is number
        && request.resource.data.bet > 0
        && request.resource.data.bet < 100000000
        && request.resource.data.payout is number
        && request.resource.data.payout > 0
        && request.resource.data.payout < 100000000
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64;
      allow update, delete: if false;
    }

    // Per-client server-time pings used to align Rocket rounds.
    match /rocketClock/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Rocket table chat.
    match /rocketChat/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 160
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64;
      allow update, delete: if false;
    }

    // Roulette live-table wins, scoped by deterministic round id.
    match /rouletteRoundWins/{roundId}/wins/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.roundId == roundId
        && request.resource.data.number is string
        && request.resource.data.number.size() > 0
        && request.resource.data.number.size() <= 2
        && request.resource.data.color is string
        && request.resource.data.color.size() > 0
        && request.resource.data.color.size() < 16
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() < 96
        && request.resource.data.bet is number
        && request.resource.data.bet > 0
        && request.resource.data.bet < 100000000
        && request.resource.data.payout is number
        && request.resource.data.payout > 0
        && request.resource.data.payout < 100000000
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64;
      allow update, delete: if false;
    }

    // Per-client server-time pings used to align Roulette rounds.
    match /rouletteClock/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Roulette table chat.
    match /rouletteChat/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 160
        && request.resource.data.player is string
        && request.resource.data.player.size() < 64;
      allow update, delete: if false;
    }

    // Per-user stats: public read (for future leaderboards), owner-only write.
    match /users/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
